# ── Front-end (públicas) — obrigatórias no Vercel, Render e no .env local ──
# Dashboard Supabase → Settings → API
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-publica

# ── Apenas servidor (NUNCA expor no front-end) ──
# Usadas pelas Server Functions (cadastro de técnico, reset de senha).
# Configure no Vercel: Project → Settings → Environment Variables.
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role

# Segredo para o endpoint único de bootstrap do admin (createInitialAdmin).
ADMIN_SETUP_SECRET=estrategic-setup-2026

# ── Scripts locais (npm run setup:admin) — não necessário no Render ──
ADMIN_SETUP_SECRET=estrategic-setup-2026
ADMIN_EMAIL=admin@estrategic.com
ADMIN_PASSWORD=
ADMIN_NAME=Administrador Estrategic
